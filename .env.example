# --- LLM provider -----------------------------------------------------------
# Leave GOOGLE_API_KEY empty to run fully offline with the deterministic stub.
GOOGLE_API_KEY=
# auto | gemini | stub   (auto -> gemini if a key is present, else stub)
LLM_PROVIDER=auto
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FALLBACK=

# --- Self-consistency sampling ----------------------------------------------
SELF_CONSISTENCY_N=5
SELF_CONSISTENCY_TEMPERATURE=0.5

# --- Routing thresholds (documented assumptions) ----------------------------
FIELD_REVIEW_THRESHOLD=0.70
TYPE_ENTROPY_REVIEW_THRESHOLD=0.35
DQ_REVIEW_THRESHOLD=0.75
GROUNDEDNESS_MIN_SCORE=0.60

# --- Persistence ------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://asset:asset@localhost:5432/asset_servicing

# --- Behaviour --------------------------------------------------------------
USE_LLM_CACHE=true
REPLAY_ONLY=false
