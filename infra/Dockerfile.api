# CAA backend API image.
FROM python:3.12-slim

# uv for fast, reproducible installs
COPY --from=ghcr.io/astral-sh/uv:0.11 /uv /uvx /bin/

ENV PYTHONUNBUFFERED=1 UV_LINK_MODE=copy
WORKDIR /app/backend

# Native runtime deps:
#  - WeasyPrint: Pango (pulls cairo/harfbuzz/fontconfig) + base fonts for the PDF artifacts.
#  - Tesseract (+ Portuguese): OCR for scanned notices so the offline extractor gets a text layer.
RUN apt-get update && apt-get install -y --no-install-recommends \
        libpango-1.0-0 libpangoft2-1.0-0 fonts-dejavu-core \
        tesseract-ocr tesseract-ocr-por \
    && rm -rf /var/lib/apt/lists/*

# 1) Dependency layer (cached): resolve deps without building the local project.
COPY backend/pyproject.toml /app/backend/
RUN uv sync --no-dev --no-install-project

# 2) App code + the read-only data the agent needs.
COPY backend /app/backend
COPY documents /app/documents
COPY golden_records /app/golden_records
COPY frontend/assets/logo.png /app/frontend/assets/logo.png
RUN uv sync --no-dev && mkdir -p /app/uploads /app/outputs /app/.cache

EXPOSE 8000
CMD ["uv", "run", "uvicorn", "app.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
